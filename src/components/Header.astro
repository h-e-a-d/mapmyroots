---
import { t, localizedPath, type Locale } from '@/i18n';

export interface Props {
  showLanguageSwitcher?: boolean;
  locale?: Locale;
}
const { showLanguageSwitcher = true, locale = 'en' } = Astro.props;
const base = locale === 'en' ? '' : `/${locale}`;
---

<header class="header" id="header">
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href={localizedPath(locale, '/')} class="logo" aria-label="MapMyRoots Home - Free Family Tree Builder">
      <div class="logo-icon">🌳</div>
      <span>MapMyRoots</span>
    </a>

    <ul class="nav-menu">
      <li><a href={`${base}/#features`} class="nav-link">{t(locale, 'nav.features')}</a></li>
      <li><a href={`${base}/#how-it-works`} class="nav-link">{t(locale, 'nav.how_it_works')}</a></li>
      <li><a href={`${base}/#examples`} class="nav-link">{t(locale, 'nav.examples')}</a></li>
      <li><a href={`${base}/#faq`} class="nav-link">{t(locale, 'nav.faq')}</a></li>
      <li><a href={localizedPath(locale, '/glossary')} class="nav-link">{t(locale, 'nav.glossary')}</a></li>
    </ul>

    <div class="nav-actions">
      {showLanguageSwitcher && (
        <div class="language-switcher desktop-only" id="language-switcher">
          <button class="language-button" id="language-button" aria-label="Select language" aria-expanded="false" aria-haspopup="true">
            <span class="language-flag" id="current-flag">🇺🇸</span>
            <span id="current-language">EN</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="language-dropdown" id="language-dropdown" role="menu" aria-labelledby="language-button">
            <button class="language-option" data-lang="en" data-flag="🇺🇸" role="menuitem"><span class="language-flag">🇺🇸</span><span>English</span></button>
            <button class="language-option" data-lang="es" data-flag="🇪🇸" role="menuitem"><span class="language-flag">🇪🇸</span><span>Español</span></button>
            <button class="language-option" data-lang="ru" data-flag="🇷🇺" role="menuitem"><span class="language-flag">🇷🇺</span><span>Русский</span></button>
            <button class="language-option" data-lang="de" data-flag="🇩🇪" role="menuitem"><span class="language-flag">🇩🇪</span><span>Deutsch</span></button>
          </div>
        </div>
      )}

      <a href="/builder" class="cta-button">{t(locale, 'nav.start_building')}</a>

      <button class="mobile-menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="mobile-menu" id="mobile-menu-toggle">
        <span class="hamburger-icon">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-labelledby="mobile-menu-title">
    <div class="mobile-menu-content">
      <h2 id="mobile-menu-title" class="sr-only">Navigation Menu</h2>
      <ul role="menu">
        <li role="none"><a href="/#features" class="nav-link" role="menuitem">Features</a></li>
        <li role="none"><a href="/#how-it-works" class="nav-link" role="menuitem">How It Works</a></li>
        <li role="none"><a href="/#examples" class="nav-link" role="menuitem">Examples</a></li>
        <li role="none"><a href="/#faq" class="nav-link" role="menuitem">FAQ</a></li>
        <li role="none"><a href="/glossary" class="nav-link" role="menuitem">Glossary</a></li>
      </ul>

      {showLanguageSwitcher && (
        <div class="mobile-language-switcher">
          <h3 class="mobile-language-title">Select Language</h3>
          <div class="mobile-language-options" role="menu">
            <button class="mobile-language-option" data-lang="en" data-flag="🇺🇸" role="menuitem"><span class="language-flag">🇺🇸</span><span>English</span></button>
            <button class="mobile-language-option" data-lang="es" data-flag="🇪🇸" role="menuitem"><span class="language-flag">🇪🇸</span><span>Español</span></button>
            <button class="mobile-language-option" data-lang="ru" data-flag="🇷🇺" role="menuitem"><span class="language-flag">🇷🇺</span><span>Русский</span></button>
            <button class="mobile-language-option" data-lang="de" data-flag="🇩🇪" role="menuitem"><span class="language-flag">🇩🇪</span><span>Deutsch</span></button>
          </div>
        </div>
      )}
    </div>
  </div>
</header>

<style>
  .language-switcher { position: relative; display: inline-block; }
  .language-button {
    background: none;
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: var(--transition);
    color: var(--text-primary);
    font-size: 0.9rem;
  }
  .language-button:hover { border-color: var(--primary-color); background: rgba(15, 134, 108, 0.05); }
  .language-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    background: var(--background-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-card);
    box-shadow: var(--shadow);
    z-index: 1000;
    min-width: 150px;
    display: none;
  }
  .language-dropdown.open { display: block; }
  .language-option {
    padding: 0.75rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: var(--transition);
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    color: var(--text-primary);
  }
  .language-option:hover { background: var(--background-alt); }
  .language-option.active { background: rgba(15, 134, 108, 0.1); color: var(--primary-color); font-weight: 600; }
  .language-flag { font-size: 1.2rem; }
</style>

<script>
  import '/src/features/i18n/i18n.js';
  import '/src/features/i18n/language-switcher.js';
  import '/src/ui/components/homepage.js';
</script>
