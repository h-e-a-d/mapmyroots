---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/homepage.css';
import { t, type Locale } from '@/i18n';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const title = t(locale, 'meta.title');
const description = t(locale, 'meta.description');

const softwareSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "MapMyRoots",
  "alternateName": ["Family Tree Builder", "Genealogy Software", "Family Tree Maker"],
  "description": "Free online family tree builder and genealogy software. Create beautiful, interactive family trees with drag-and-drop interface. Preserve family history, connect relatives, and visualize ancestry.",
  "url": "https://mapmyroots.com",
  "applicationCategory": ["Genealogy Software", "Family Tree Software", "Heritage Software"],
  "operatingSystem": ["Web Browser", "Windows", "macOS", "Linux", "iOS", "Android"],
  "browserRequirements": "Requires JavaScript. Supports Chrome, Firefox, Safari, Edge.",
  "softwareVersion": "2.1.0",
  "datePublished": "2023-01-15",
  "dateModified": "2026-04-29",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  },
  "featureList": [
    "Drag & Drop Interface",
    "Interactive Canvas",
    "Rich Family Profiles",
    "Multiple View Modes",
    "Export & Share Options",
    "Unlimited Family Trees",
    "Free Forever"
  ]
});

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MapMyRoots",
  "url": "https://mapmyroots.com",
  "logo": "https://mapmyroots.com/icon-512.png",
  "description": "Free family tree builder and genealogy software for preserving family history",
  "foundingDate": "2023-01-15",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Support",
    "email": "support@mapmyroots.com"
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is MapMyRoots completely free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, MapMyRoots is completely free with no hidden costs, subscription fees, or premium tiers. You can create unlimited family trees and access all features forever." } },
    { "@type": "Question", "name": "How does MapMyRoots compare to Ancestry.com or MyHeritage?", "acceptedAnswer": { "@type": "Answer", "text": "Unlike paid services like Ancestry.com or MyHeritage, MapMyRoots is completely free and focuses on family tree visualization rather than genealogical research. You own your data and can export it anytime." } },
    { "@type": "Question", "name": "What file formats can I export my family tree in?", "acceptedAnswer": { "@type": "Answer", "text": "You can export your family tree as high-resolution images (PNG, JPG), PDF documents for printing, or JSON data for backup and sharing with other genealogy software." } },
    { "@type": "Question", "name": "Do I need to register or create an account?", "acceptedAnswer": { "@type": "Answer", "text": "No registration required and no account needed. You can start building your family tree immediately. All your data is stored locally on your device, so you keep full control." } },
    { "@type": "Question", "name": "Can I use MapMyRoots on mobile devices?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, MapMyRoots works perfectly on desktop computers, tablets, and mobile phones. The responsive design adapts to your screen size while maintaining full functionality." } },
    { "@type": "Question", "name": "How many people can I add to my family tree?", "acceptedAnswer": { "@type": "Answer", "text": "There's no limit! You can add as many family members as you want and create multiple family trees. Users have successfully created trees with hundreds of family members." } },
    { "@type": "Question", "name": "Can I import data from Ancestry.com or other services?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Use the Import button in the builder to load a GEDCOM file (.ged) — the universal genealogy format supported by Ancestry, MyHeritage, FamilySearch, and most genealogy software. From those services, export your tree as GEDCOM, then import it here." } },
    { "@type": "Question", "name": "How do I print my family tree?", "acceptedAnswer": { "@type": "Answer", "text": "Export your family tree as a high-resolution PNG or PDF file using the export menu. These formats are perfect for printing at any size, from standard paper to large format posters." } },
    { "@type": "Question", "name": "How do I back up my family tree data?", "acceptedAnswer": { "@type": "Answer", "text": "Use the export feature to download your family tree as a JSON file. Save this to your computer, cloud storage, or USB drive. You can reload it anytime using the import feature." } },
    { "@type": "Question", "name": "Is my family data private and secure?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely! Your family tree data is stored locally on your device using browser LocalStorage. It never leaves your device and we never see or access it." } }
  ]
});

---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  locale={locale}
  jsonLd={[softwareSchema, orgSchema, ...(locale === 'en' ? [faqSchema] : [])]}
>
    <section class="hero" aria-labelledby="hero-title">
      <img class="hero-bg" src="/assets/images/tree.webp" alt="" aria-hidden="true" fetchpriority="high" loading="eager" decoding="async" />
      <div class="hero-content">
        <h1 id="hero-title" data-i18n="hero.title">{t(locale, 'hero.title')}</h1>
        <p class="hero-subtitle" data-i18n="hero.subtitle">{t(locale, 'hero.subtitle')}</p>

        <!-- Trust Signals -->
        <div class="trust-signals">
          <div class="trust-item">
            <span class="trust-number">15,000+</span>
            <span class="trust-label" data-i18n="hero.trust.families">{t(locale, 'hero.trust.families')}</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">100%</span>
            <span class="trust-label" data-i18n="hero.trust.free">{t(locale, 'hero.trust.free')}</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">4.8★</span>
            <span class="trust-label" data-i18n="hero.trust.rating">{t(locale, 'hero.trust.rating')}</span>
          </div>
        </div>

        <div class="hero-buttons">
          <a href="/builder" class="btn-primary" data-gtm-event="cta_click" data-gtm-location="hero">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polygon points="10,8 16,12 10,16 10,8"/>
            </svg>
            <span data-i18n="hero.buttons.start_building">{t(locale, 'hero.buttons.start_building')}</span>
          </a>
          <a href="https://youtu.be/-h7E-F7frA8" class="btn-secondary" data-gtm-event="demo_click" data-gtm-location="hero">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5,3 19,12 5,21 5,3"/>
            </svg>
            <span data-i18n="hero.buttons.watch_demo">{t(locale, 'hero.buttons.watch_demo')}</span>
          </a>
        </div>

        <p class="hero-note" data-i18n="hero.note">{t(locale, 'hero.note')}</p>
      </div>
    </section>

    <!-- What is MapMyRoots Section -->
    <section class="about-section" id="about" aria-labelledby="about-title">
      <div class="container">
        <div class="about-content">
          <div class="about-text">
            <h2 id="about-title" data-i18n="about.title">{t(locale, 'about.title')}</h2>
            <p class="about-description" data-i18n="about.description" set:html={t(locale, 'about.description')}></p>

            <div class="key-points">
              <div class="key-point">
                <h3 data-i18n="about.points.purpose.title">{t(locale, 'about.points.purpose.title')}</h3>
                <p data-i18n="about.points.purpose.description">{t(locale, 'about.points.purpose.description')}</p>
              </div>
              <div class="key-point">
                <h3 data-i18n="about.points.free.title">{t(locale, 'about.points.free.title')}</h3>
                <p data-i18n="about.points.free.description">{t(locale, 'about.points.free.description')}</p>
              </div>
              <div class="key-point">
                <h3 data-i18n="about.points.control.title">{t(locale, 'about.points.control.title')}</h3>
                <p data-i18n="about.points.control.description">{t(locale, 'about.points.control.description')}</p>
              </div>
            </div>
          </div>
          <div class="about-image">
            <div class="demo-placeholder">
              <h4 data-i18n="about.demo.title">{t(locale, 'about.demo.title')}</h4>
              <p data-i18n="about.demo.description">{t(locale, 'about.demo.description')}</p>
              <a href="/builder" class="demo-link" data-i18n="about.demo.link">{t(locale, 'about.demo.link')}</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features" id="features" aria-labelledby="features-title">
      <div class="container">
        <header class="section-header">
          <h2 id="features-title" class="section-title fade-in" data-i18n="features.title">{t(locale, 'features.title')}</h2>
          <p class="section-subtitle fade-in" data-i18n="features.subtitle">{t(locale, 'features.subtitle')}</p>
        </header>

        <div class="features-grid">
          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.drag_drop.title">{t(locale, 'features.cards.drag_drop.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.drag_drop.description">{t(locale, 'features.cards.drag_drop.description')}</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="7.5,4.21 12,6.81 16.5,4.21"/>
                <polyline points="7.5,19.79 7.5,14.6 3,12"/>
                <polyline points="21,12 16.5,14.6 16.5,19.79"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.interactive.title">{t(locale, 'features.cards.interactive.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.interactive.description">{t(locale, 'features.cards.interactive.description')}</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10,9 9,9 8,9"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.profiles.title">{t(locale, 'features.cards.profiles.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.profiles.description">{t(locale, 'features.cards.profiles.description')}</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.views.title">{t(locale, 'features.cards.views.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.views.description">{t(locale, 'features.cards.views.description')}</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.export.title">{t(locale, 'features.cards.export.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.export.description">{t(locale, 'features.cards.export.description')}</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"/>
                <path d="M8 5v6"/>
                <path d="M16 5v6"/>
                <path d="M9 16h6"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.free.title">{t(locale, 'features.cards.free.title')}</h3>
            <p class="feature-description" data-i18n="features.cards.free.description">{t(locale, 'features.cards.free.description')}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Examples Section -->
    <section class="examples-section" id="examples" aria-labelledby="examples-title">
      <div class="container">
        <header class="section-header">
          <h2 id="examples-title" class="section-title fade-in" data-i18n="examples.title">{t(locale, 'examples.title')}</h2>
          <p class="section-subtitle fade-in" data-i18n="examples.subtitle">{t(locale, 'examples.subtitle')}</p>
        </header>

        <div class="examples-grid">
          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">👨‍👩‍👧‍👦</div>
            </div>
            <h3 data-i18n="examples.cards.reunions.title">{t(locale, 'examples.cards.reunions.title')}</h3>
            <p data-i18n="examples.cards.reunions.description">{t(locale, 'examples.cards.reunions.description')}</p>
          </article>

          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">🎓</div>
            </div>
            <h3 data-i18n="examples.cards.school.title">{t(locale, 'examples.cards.school.title')}</h3>
            <p data-i18n="examples.cards.school.description">{t(locale, 'examples.cards.school.description')}</p>
          </article>

          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">💝</div>
            </div>
            <h3 data-i18n="examples.cards.memorial.title">{t(locale, 'examples.cards.memorial.title')}</h3>
            <p data-i18n="examples.cards.memorial.description">{t(locale, 'examples.cards.memorial.description')}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="how-it-works" id="how-it-works" aria-labelledby="how-title">
      <div class="container">
        <header class="section-header">
          <h2 id="how-title" class="section-title fade-in" data-i18n="how_it_works.title">{t(locale, 'how_it_works.title')}</h2>
          <p class="section-subtitle fade-in" data-i18n="how_it_works.subtitle">{t(locale, 'how_it_works.subtitle')}</p>
        </header>

        <div class="steps">
          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="8.5" cy="7" r="4"/>
                <path d="M20 8v6"/>
                <path d="M23 11h-6"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.add.title">{t(locale, 'how_it_works.steps.add.title')}</h3>
            <p class="step-description" data-i18n="how_it_works.steps.add.description">{t(locale, 'how_it_works.steps.add.description')}</p>
          </article>

          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.5 12c0 4.4-3.6 8-8 8s-8-3.6-8-8 3.6-8 8-8"/>
                <path d="M12 2l3 3-3 3"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.connect.title">{t(locale, 'how_it_works.steps.connect.title')}</h3>
            <p class="step-description" data-i18n="how_it_works.steps.connect.description">{t(locale, 'how_it_works.steps.connect.description')}</p>
          </article>

          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.customize.title">{t(locale, 'how_it_works.steps.customize.title')}</h3>
            <p class="step-description" data-i18n="how_it_works.steps.customize.description">{t(locale, 'how_it_works.steps.customize.description')}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Comparison Section -->
    <section class="comparison-section" id="comparison" aria-labelledby="comparison-title">
      <div class="container">
        <header class="section-header">
          <h2 id="comparison-title" class="section-title fade-in" data-i18n="comparison.title">{t(locale, 'comparison.title')}</h2>
          <p class="section-subtitle fade-in" data-i18n="comparison.subtitle">{t(locale, 'comparison.subtitle')}</p>
        </header>

        <div class="comparison-table fade-in">
          <div class="comparison-header">
            <div class="comparison-feature" data-i18n="comparison.header.feature">{t(locale, 'comparison.header.feature')}</div>
            <div class="comparison-us">MapMyRoots</div>
            <div class="comparison-other">Ancestry.com</div>
            <div class="comparison-other">MyHeritage</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.cost">{t(locale, 'comparison.rows.cost')}</div>
            <div class="comparison-us" data-i18n="comparison.rows.cost_us">{t(locale, 'comparison.rows.cost_us')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.cost_ancestry">{t(locale, 'comparison.rows.cost_ancestry')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.cost_heritage">{t(locale, 'comparison.rows.cost_heritage')}</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.builder">{t(locale, 'comparison.rows.builder')}</div>
            <div class="comparison-us" data-i18n="comparison.rows.builder_us">{t(locale, 'comparison.rows.builder_us')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.builder_others">{t(locale, 'comparison.rows.builder_others')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.builder_others">{t(locale, 'comparison.rows.builder_others')}</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.export">{t(locale, 'comparison.rows.export')}</div>
            <div class="comparison-us" data-i18n="comparison.rows.export_us">{t(locale, 'comparison.rows.export_us')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.export_others">{t(locale, 'comparison.rows.export_others')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.export_others">{t(locale, 'comparison.rows.export_others')}</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.registration">{t(locale, 'comparison.rows.registration')}</div>
            <div class="comparison-us" data-i18n="comparison.rows.registration_us">{t(locale, 'comparison.rows.registration_us')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.registration_others">{t(locale, 'comparison.rows.registration_others')}</div>
            <div class="comparison-other" data-i18n="comparison.rows.registration_others">{t(locale, 'comparison.rows.registration_others')}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <div class="container">
        <header class="section-header">
          <h2 id="faq-title" class="section-title fade-in" data-i18n="faq.title">{t(locale, 'faq.title')}</h2>
          <p class="section-subtitle fade-in" data-i18n="faq.subtitle">{t(locale, 'faq.subtitle')}</p>
        </header>

        <div class="faq-grid">
          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.free.question">{t(locale, 'faq.free.question')}</h3>
            <div class="faq-answer">
              <p data-i18n="faq.free.answer">{t(locale, 'faq.free.answer')}</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.compare.question">{t(locale, 'faq.compare.question')}</h3>
            <div class="faq-answer">
              <p data-i18n="faq.compare.answer">{t(locale, 'faq.compare.answer')}</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.export.question">{t(locale, 'faq.export.question')}</h3>
            <div class="faq-answer">
              <p data-i18n="faq.export.answer">{t(locale, 'faq.export.answer')}</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.register.question">{t(locale, 'faq.register.question')}</h3>
            <div class="faq-answer">
              <p data-i18n="faq.register.answer">{t(locale, 'faq.register.answer')}</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.mobile.question">{t(locale, 'faq.mobile.question')}</h3>
            <div class="faq-answer">
              <p data-i18n="faq.mobile.answer">{t(locale, 'faq.mobile.answer')}</p>
            </div>
