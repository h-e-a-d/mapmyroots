---
import BaseLayout from '@/layouts/BaseLayout.astro';
import '@/styles/homepage.css';
import { t, type Locale } from '@/i18n';

export interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const title = t(locale, 'meta.title');
const description = t(locale, 'meta.description');

const softwareSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "MapMyRoots",
  "alternateName": ["Family Tree Builder", "Genealogy Software", "Family Tree Maker"],
  "description": "Free online family tree builder and genealogy software. Create beautiful, interactive family trees with drag-and-drop interface. Preserve family history, connect relatives, and visualize ancestry.",
  "url": "https://mapmyroots.com",
  "applicationCategory": ["Genealogy Software", "Family Tree Software", "Heritage Software"],
  "operatingSystem": ["Web Browser", "Windows", "macOS", "Linux", "iOS", "Android"],
  "browserRequirements": "Requires JavaScript. Supports Chrome, Firefox, Safari, Edge.",
  "softwareVersion": "2.1.0",
  "datePublished": "2023-01-15",
  "dateModified": "2026-04-29",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  },
  "featureList": [
    "Drag & Drop Interface",
    "Interactive Canvas",
    "Rich Family Profiles",
    "Multiple View Modes",
    "Export & Share Options",
    "Unlimited Family Trees",
    "Free Forever"
  ]
});

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MapMyRoots",
  "url": "https://mapmyroots.com",
  "logo": "https://mapmyroots.com/logo.png",
  "description": "Free family tree builder and genealogy software for preserving family history",
  "foundingDate": "2023-01-15",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "Customer Support",
    "email": "support@mapmyroots.com"
  }
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Is MapMyRoots completely free to use?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, MapMyRoots is completely free with no hidden costs, subscription fees, or premium tiers. You can create unlimited family trees and access all features forever." } },
    { "@type": "Question", "name": "How does MapMyRoots compare to Ancestry.com or MyHeritage?", "acceptedAnswer": { "@type": "Answer", "text": "Unlike paid services like Ancestry.com or MyHeritage, MapMyRoots is completely free and focuses on family tree visualization rather than genealogical research. You own your data and can export it anytime." } },
    { "@type": "Question", "name": "What file formats can I export my family tree in?", "acceptedAnswer": { "@type": "Answer", "text": "You can export your family tree as high-resolution images (PNG, JPG), PDF documents for printing, or JSON data for backup and sharing with other genealogy software." } },
    { "@type": "Question", "name": "Do I need to register or create an account?", "acceptedAnswer": { "@type": "Answer", "text": "No registration required and no account needed. You can start building your family tree immediately. All your data is stored locally on your device, so you keep full control." } },
    { "@type": "Question", "name": "Can I use MapMyRoots on mobile devices?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, MapMyRoots works perfectly on desktop computers, tablets, and mobile phones. The responsive design adapts to your screen size while maintaining full functionality." } },
    { "@type": "Question", "name": "How many people can I add to my family tree?", "acceptedAnswer": { "@type": "Answer", "text": "There's no limit! You can add as many family members as you want and create multiple family trees. Users have successfully created trees with hundreds of family members." } },
    { "@type": "Question", "name": "Can I import data from Ancestry.com or other services?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! Use the Import button in the builder to load a GEDCOM file (.ged) — the universal genealogy format supported by Ancestry, MyHeritage, FamilySearch, and most genealogy software. From those services, export your tree as GEDCOM, then import it here." } },
    { "@type": "Question", "name": "How do I print my family tree?", "acceptedAnswer": { "@type": "Answer", "text": "Export your family tree as a high-resolution PNG or PDF file using the export menu. These formats are perfect for printing at any size, from standard paper to large format posters." } },
    { "@type": "Question", "name": "How do I back up my family tree data?", "acceptedAnswer": { "@type": "Answer", "text": "Use the export feature to download your family tree as a JSON file. Save this to your computer, cloud storage, or USB drive. You can reload it anytime using the import feature." } },
    { "@type": "Question", "name": "Is my family data private and secure?", "acceptedAnswer": { "@type": "Answer", "text": "Absolutely! Your family tree data is stored locally on your device using browser LocalStorage. It never leaves your device and we never see or access it." } }
  ]
});

const howToSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Build Your Family Tree with MapMyRoots",
  "description": "Step-by-step guide to creating a comprehensive family tree using MapMyRoots free family tree builder.",
  "totalTime": "PT10M",
  "estimatedCost": { "@type": "MonetaryAmount", "currency": "USD", "value": "0" },
  "tool": [{ "@type": "HowToTool", "name": "MapMyRoots Family Tree Builder" }],
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Add Family Members", "text": "Start by adding yourself and begin building outward.", "url": "https://mapmyroots.com/#how-it-works" },
    { "@type": "HowToStep", "position": 2, "name": "Connect Relationships", "text": "Use our simple connection tools to link family members.", "url": "https://mapmyroots.com/#how-it-works" },
    { "@type": "HowToStep", "position": 3, "name": "Customize & Share", "text": "Personalize your tree and export.", "url": "https://mapmyroots.com/#how-it-works" }
  ]
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mapmyroots.com/" }]
});
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  locale={locale}
  jsonLd={[softwareSchema, orgSchema, faqSchema, howToSchema, breadcrumbSchema]}
>
    <section class="hero" aria-labelledby="hero-title" style="background-image: url('/assets/images/tree.webp');">
      <div class="hero-content">
        <h1 id="hero-title" data-i18n="hero.title">Free Family Tree Builder & Genealogy Software</h1>
        <p class="hero-subtitle" data-i18n="hero.subtitle">Create beautiful, interactive family trees with our intuitive drag-and-drop interface. Build unlimited family trees, preserve memories, and discover your family heritage - completely free forever.</p>

        <!-- Trust Signals -->
        <div class="trust-signals">
          <div class="trust-item">
            <span class="trust-number">15,000+</span>
            <span class="trust-label" data-i18n="hero.trust.families">Families Trust Us</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">100%</span>
            <span class="trust-label" data-i18n="hero.trust.free">Free Forever</span>
          </div>
          <div class="trust-item">
            <span class="trust-number">4.8★</span>
            <span class="trust-label" data-i18n="hero.trust.rating">User Rating</span>
          </div>
        </div>

        <div class="hero-buttons">
          <a href="/builder" class="btn-primary" data-gtm-event="cta_click" data-gtm-location="hero">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polygon points="10,8 16,12 10,16 10,8"/>
            </svg>
            <span data-i18n="hero.buttons.start_building">Start Building Free</span>
          </a>
          <a href="https://youtu.be/-h7E-F7frA8" class="btn-secondary" data-gtm-event="demo_click" data-gtm-location="hero">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5,3 19,12 5,21 5,3"/>
            </svg>
            <span data-i18n="hero.buttons.watch_demo">Watch Demo (2 min)</span>
          </a>
        </div>

        <p class="hero-note" data-i18n="hero.note">✓ No registration required ✓ No credit card needed ✓ Export anytime</p>
      </div>
    </section>

    <!-- What is MapMyRoots Section -->
    <section class="about-section" id="about" aria-labelledby="about-title">
      <div class="container">
        <div class="about-content">
          <div class="about-text">
            <h2 id="about-title" data-i18n="about.title">What is MapMyRoots?</h2>
            <p class="about-description" data-i18n="about.description">MapMyRoots is a <strong>free online family tree creation tool</strong> that helps you visualize and preserve your family history. Unlike expensive genealogy services, we focus on making family tree building simple, beautiful, and accessible to everyone.</p>

            <div class="key-points">
              <div class="key-point">
                <h3 data-i18n="about.points.purpose.title">🎯 Purpose-Built for Family Trees</h3>
                <p data-i18n="about.points.purpose.description">Designed specifically for creating visual family trees, not overwhelming genealogy research</p>
              </div>
              <div class="key-point">
                <h3 data-i18n="about.points.free.title">💰 Completely Free</h3>
                <p data-i18n="about.points.free.description">No subscription fees, premium tiers, or hidden costs. All features included forever</p>
              </div>
              <div class="key-point">
                <h3 data-i18n="about.points.control.title">🔒 Your Data, Your Control</h3>
                <p data-i18n="about.points.control.description">Export your family trees anytime in multiple formats. No vendor lock-in</p>
              </div>
            </div>
          </div>
          <div class="about-image">
            <div class="demo-placeholder">
              <h4 data-i18n="about.demo.title">Interactive Family Tree Preview</h4>
              <p data-i18n="about.demo.description">See how easy it is to build beautiful family trees</p>
              <a href="/builder" class="demo-link" data-i18n="about.demo.link">Try Live Demo →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features" id="features" aria-labelledby="features-title">
      <div class="container">
        <header class="section-header">
          <h2 id="features-title" class="section-title fade-in" data-i18n="features.title">Powerful Family Tree Features</h2>
          <p class="section-subtitle fade-in" data-i18n="features.subtitle">Everything you need to create comprehensive family trees and preserve your family history</p>
        </header>

        <div class="features-grid">
          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.drag_drop.title">Intuitive Drag & Drop Interface</h3>
            <p class="feature-description" data-i18n="features.cards.drag_drop.description">Build family trees effortlessly with our intuitive drag-and-drop interface. Add, move, and connect family members with simple gestures. Perfect for genealogy beginners and experts alike.</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="7.5,4.21 12,6.81 16.5,4.21"/>
                <polyline points="7.5,19.79 7.5,14.6 3,12"/>
                <polyline points="21,12 16.5,14.6 16.5,19.79"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.interactive.title">Interactive Family Tree Canvas</h3>
            <p class="feature-description" data-i18n="features.cards.interactive.description">Beautiful, responsive family trees with smooth animations, zoom controls, and multiple viewing modes. Works perfectly on desktop, tablet, and mobile devices.</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10,9 9,9 8,9"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.profiles.title">Detailed Family Profiles</h3>
            <p class="feature-description" data-i18n="features.cards.profiles.description">Store comprehensive information for each family member including names, birth/death dates, relationships, photos, and personal notes. Build rich family histories.</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7"/>
                <rect x="14" y="3" width="7" height="7"/>
                <rect x="14" y="14" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.views.title">Multiple View Modes</h3>
            <p class="feature-description" data-i18n="features.cards.views.description">Switch between visual tree view and organized table view. Sort, filter, and search your family data in the way that works best for your genealogy research.</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.export.title">Export & Share Options</h3>
            <p class="feature-description" data-i18n="features.cards.export.description">Export your family tree as high-resolution images, PDFs for printing, or JSON data for backup. Share your family history with relatives worldwide.</p>
          </article>

          <article class="feature-card fade-in">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z"/>
                <path d="M8 5v6"/>
                <path d="M16 5v6"/>
                <path d="M9 16h6"/>
              </svg>
            </div>
            <h3 class="feature-title" data-i18n="features.cards.free.title">100% Free Forever</h3>
            <p class="feature-description" data-i18n="features.cards.free.description">No hidden costs, subscription fees, or premium features. Build unlimited family trees and preserve your family history forever, completely free.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Examples Section -->
    <section class="examples-section" id="examples" aria-labelledby="examples-title">
      <div class="container">
        <header class="section-header">
          <h2 id="examples-title" class="section-title fade-in" data-i18n="examples.title">Family Tree Examples & Use Cases</h2>
          <p class="section-subtitle fade-in" data-i18n="examples.subtitle">See how families use MapMyRoots for different purposes</p>
        </header>

        <div class="examples-grid">
          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">👨‍👩‍👧‍👦</div>
            </div>
            <h3 data-i18n="examples.cards.reunions.title">Family Reunions</h3>
            <p data-i18n="examples.cards.reunions.description">Perfect for family reunions - create large-format trees to display at events and help relatives connect</p>
          </article>

          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">🎓</div>
            </div>
            <h3 data-i18n="examples.cards.school.title">School Projects</h3>
            <p data-i18n="examples.cards.school.description">Students love using MapMyRoots for genealogy assignments and family history projects</p>
          </article>

          <article class="example-card fade-in">
            <div class="example-image">
              <div class="example-placeholder">💝</div>
            </div>
            <h3 data-i18n="examples.cards.memorial.title">Memorial Gifts</h3>
            <p data-i18n="examples.cards.memorial.description">Create beautiful family trees as memorial gifts or to preserve the legacy of elderly relatives</p>
          </article>
        </div>
      </div>
    </section>

    <section class="how-it-works" id="how-it-works" aria-labelledby="how-title">
      <div class="container">
        <header class="section-header">
          <h2 id="how-title" class="section-title fade-in" data-i18n="how_it_works.title">How to Build Your Family Tree</h2>
          <p class="section-subtitle fade-in" data-i18n="how_it_works.subtitle">Get started in minutes with our simple 3-step process</p>
        </header>

        <div class="steps">
          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="8.5" cy="7" r="4"/>
                <path d="M20 8v6"/>
                <path d="M23 11h-6"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.add.title">Add Family Members</h3>
            <p class="step-description" data-i18n="how_it_works.steps.add.description">Start by adding yourself and begin building outward. Add parents, siblings, children, and extended family with detailed profiles including photos and personal information.</p>
          </article>

          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.5 12c0 4.4-3.6 8-8 8s-8-3.6-8-8 3.6-8 8-8"/>
                <path d="M12 2l3 3-3 3"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.connect.title">Connect Relationships</h3>
            <p class="step-description" data-i18n="how_it_works.steps.connect.description">Use our simple connection tools to link family members. Define relationships like parent-child, spouse, or custom connections. The family tree updates automatically.</p>
          </article>

          <article class="step fade-in">
            <div class="step-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <h3 class="step-title" data-i18n="how_it_works.steps.customize.title">Customize & Share</h3>
            <p class="step-description" data-i18n="how_it_works.steps.customize.description">Personalize your tree with colors and styles. Export as beautiful high-resolution images, PDFs for printing, or share your family history digitally with loved ones.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Comparison Section -->
    <section class="comparison-section" id="comparison" aria-labelledby="comparison-title">
      <div class="container">
        <header class="section-header">
          <h2 id="comparison-title" class="section-title fade-in" data-i18n="comparison.title">Why Choose MapMyRoots?</h2>
          <p class="section-subtitle fade-in" data-i18n="comparison.subtitle">See how we compare to other family tree software</p>
        </header>

        <div class="comparison-table fade-in">
          <div class="comparison-header">
            <div class="comparison-feature" data-i18n="comparison.header.feature">Feature</div>
            <div class="comparison-us">MapMyRoots</div>
            <div class="comparison-other">Ancestry.com</div>
            <div class="comparison-other">MyHeritage</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.cost">Monthly Cost</div>
            <div class="comparison-us" data-i18n="comparison.rows.cost_us">✅ Free Forever</div>
            <div class="comparison-other" data-i18n="comparison.rows.cost_ancestry">❌ $24.99/month</div>
            <div class="comparison-other" data-i18n="comparison.rows.cost_heritage">❌ $12.95/month</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.builder">Family Tree Builder</div>
            <div class="comparison-us" data-i18n="comparison.rows.builder_us">✅ Advanced</div>
            <div class="comparison-other" data-i18n="comparison.rows.builder_others">✅ Basic</div>
            <div class="comparison-other" data-i18n="comparison.rows.builder_others">✅ Basic</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.export">Export Options</div>
            <div class="comparison-us" data-i18n="comparison.rows.export_us">✅ All Formats</div>
            <div class="comparison-other" data-i18n="comparison.rows.export_others">❌ Limited</div>
            <div class="comparison-other" data-i18n="comparison.rows.export_others">❌ Limited</div>
          </div>

          <div class="comparison-row">
            <div class="comparison-feature" data-i18n="comparison.rows.registration">No Registration</div>
            <div class="comparison-us" data-i18n="comparison.rows.registration_us">✅ Start Immediately</div>
            <div class="comparison-other" data-i18n="comparison.rows.registration_others">❌ Required</div>
            <div class="comparison-other" data-i18n="comparison.rows.registration_others">❌ Required</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <div class="container">
        <header class="section-header">
          <h2 id="faq-title" class="section-title fade-in" data-i18n="faq.title">Frequently Asked Questions</h2>
          <p class="section-subtitle fade-in" data-i18n="faq.subtitle">Everything you need to know about MapMyRoots family tree software</p>
        </header>

        <div class="faq-grid">
          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.free.question">Is MapMyRoots completely free to use?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.free.answer">Yes, MapMyRoots is completely free with no hidden costs, subscription fees, or premium tiers. You can create unlimited family trees and access all features forever. We believe family history preservation should be accessible to everyone.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.compare.question">How does MapMyRoots compare to Ancestry.com or MyHeritage?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.compare.answer">Unlike paid services like Ancestry.com ($24.99/month) or MyHeritage ($12.95/month), MapMyRoots is completely free and focuses on family tree visualization rather than genealogical research. You own your data and can export it anytime in multiple formats.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.export.question">What file formats can I export my family tree in?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.export.answer">You can export your family tree as high-resolution images (PNG, JPG), PDF documents perfect for printing, or JSON data for backup and sharing with other genealogy software. No restrictions or watermarks.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.register.question">Do I need to register or create an account?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.register.answer">No registration required and no account needed. You can start building your family tree immediately. All your data is stored locally on your device, so you keep full control.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.mobile.question">Can I use MapMyRoots on mobile devices?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.mobile.answer">Yes, MapMyRoots works perfectly on desktop computers, tablets, and mobile phones. The responsive design adapts to your screen size while maintaining full functionality.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.limit.question">How many people can I add to my family tree?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.limit.answer">There's no limit! You can add as many family members as you want and create multiple family trees. Users have successfully created trees with hundreds of family members.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.import.question">Can I import data from Ancestry.com or other services?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.import.answer">Yes! Use the Import button in the builder to load a GEDCOM file (.ged) — the universal genealogy format supported by Ancestry, MyHeritage, FamilySearch, and most genealogy software. From those services, export your tree as GEDCOM, then import it here.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.photos.question">Can I add photos of family members?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.photos.answer">Yes — click Edit on any person and add a photo. Photos are resized and stored locally on your device.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.print.question">How do I print my family tree?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.print.answer">You can export your family tree as a high-resolution PNG or PDF file using the export menu in the builder. These formats are perfect for printing at any size, from standard paper to large format posters for family reunions.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.backup.question">How do I back up my family tree data?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.backup.answer">Regular backups are essential! Use the export feature to download your family tree as a JSON file. Save this file to your computer, cloud storage, or USB drive. You can reload it anytime using the import feature.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.browsers.question">What browsers does MapMyRoots support?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.browsers.answer">MapMyRoots works on all modern browsers including Chrome, Firefox, Safari, and Edge. We recommend using the latest version of your preferred browser for the best experience.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.share.question">Can I share my family tree with relatives?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.share.answer">Yes! Export your family tree as an image, PDF, or JSON file and share it via email, cloud storage, or messaging apps. Recipients can view images/PDFs directly or import the JSON file into their own MapMyRoots to continue editing.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.privacy.question">Is my family data private and secure?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.privacy.answer">Absolutely! Your family tree data is stored locally on your device using browser LocalStorage. It never leaves your device and we never see or access it. You have complete privacy and control over your family information.</p>
            </div>
          </div>

          <div class="faq-item fade-in">
            <h3 class="faq-question" data-i18n="faq.collaborate.question">Can multiple people work on the same family tree?</h3>
            <div class="faq-answer">
              <p data-i18n="faq.collaborate.answer">While real-time collaboration isn't currently supported, you can share your family tree JSON file with others. They can import it, make changes, and send it back. You can then merge the updates into your version.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

