---
import BaseLayout from '@/layouts/BaseLayout.astro';

const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "MapMyRoots",
  "url": "https://mapmyroots.com",
  "logo": "https://mapmyroots.com/logo.png",
  "description": "Free family tree builder and genealogy software for preserving family history"
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mapmyroots.com/" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://mapmyroots.com/about" }
  ]
});
---

<BaseLayout
  title="About Us - MapMyRoots | Free Family Tree Builder"
  description="Learn about MapMyRoots - our mission to make family history preservation accessible to everyone through free, privacy-focused family tree software."
  canonicalPath="/about"
  jsonLd={[orgSchema, breadcrumbSchema]}
>
    <div class="about-container">
      <div class="about-hero">
        <h1 data-i18n="about.hero.title">About MapMyRoots</h1>
        <p class="subtitle" data-i18n="about.hero.subtitle">Making family history preservation accessible, free, and privacy-focused for everyone.</p>
      </div>

      <div class="mission-box">
        <h2 data-i18n="about.mission.title">Our Mission</h2>
        <p data-i18n="about.mission.content">To empower families worldwide to create, visualize, and preserve their family histories without barriers. We believe that documenting your heritage should be free, simple, and private - accessible to everyone, not just those who can afford expensive genealogy software.</p>
      </div>

      <div class="story-section">
        <h2 data-i18n="about.story.title">Our Story</h2>
        <p data-i18n="about.story.paragraph1">MapMyRoots was born from a simple frustration: why is creating a family tree so expensive and complicated? Most genealogy services charge monthly fees, lock your data behind paywalls, and make the process overwhelming for beginners.</p>
        <p data-i18n="about.story.paragraph2">We created MapMyRoots to solve this problem. Launched in 2023, our platform provides a completely free, intuitive family tree builder that respects your privacy. Your data stays on your device - we never see it, we never store it, and we never sell it.</p>
        <p data-i18n="about.story.paragraph3">Since our launch, over 15,000 families have used MapMyRoots to preserve their heritage. From students completing school projects to grandparents documenting multiple generations, our tool serves families worldwide in their journey to understand where they come from.</p>
      </div>

      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon">🔒</div>
          <h3 data-i18n="about.values.privacy.title">Privacy First</h3>
          <p data-i18n="about.values.privacy.content">Your family tree data never leaves your device. We use browser LocalStorage to keep everything private and secure. No servers, no databases, no data collection - just you and your family history.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">💯</div>
          <h3 data-i18n="about.values.free.title">100% Free Forever</h3>
          <p data-i18n="about.values.free.content">No subscriptions, no premium tiers, no hidden costs. All features are free and always will be. Family history preservation shouldn't require a monthly payment.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">✨</div>
          <h3 data-i18n="about.values.simple.title">Simple & Intuitive</h3>
          <p data-i18n="about.values.simple.content">We focus on making family tree creation easy for everyone. Drag-and-drop interface, visual canvas, and straightforward controls mean you can start building immediately - no training required.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">🌍</div>
          <h3 data-i18n="about.values.accessible.title">Accessible to All</h3>
          <p data-i18n="about.values.accessible.content">No registration required. Works on any device with a browser. Available in multiple languages. We believe everyone should be able to document their family story, regardless of technical skill or resources.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">🎨</div>
          <h3 data-i18n="about.values.beautiful.title">Beautiful Design</h3>
          <p data-i18n="about.values.beautiful.content">Your family history deserves to be presented beautifully. Our interactive canvas, customizable styles, and high-resolution exports make your family trees stunning works of art.</p>
        </div>

        <div class="value-card">
          <div class="value-icon">🔓</div>
          <h3 data-i18n="about.values.ownership.title">Your Data, Your Control</h3>
          <p data-i18n="about.values.ownership.content">Export your family tree anytime in multiple formats (JSON, PDF, images). No vendor lock-in, no restrictions. Your data belongs to you, period.</p>
        </div>
      </div>

      <div class="stats-section">
        <h2 data-i18n="about.stats.title">MapMyRoots by the Numbers</h2>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">15,000+</div>
            <div class="stat-label" data-i18n="about.stats.families">Families Served</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label" data-i18n="about.stats.free">Free Forever</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">4.8★</div>
            <div class="stat-label" data-i18n="about.stats.rating">Average Rating</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">4</div>
            <div class="stat-label" data-i18n="about.stats.languages">Languages</div>
          </div>
        </div>
      </div>

      <div class="story-section">
        <h2 data-i18n="about.why_free.title">Why Is MapMyRoots Free?</h2>
        <p data-i18n="about.why_free.paragraph1">Great question! We believe family history preservation is a fundamental human activity that shouldn't be monetized. Unlike other genealogy services, we don't charge because:</p>
        <ul style="font-size: 1.1rem; line-height: 1.8; color: var(--text-primary); margin-left: 2rem;">
          <li data-i18n="about.why_free.reason1"><strong>Privacy-focused architecture:</strong> Since your data stays on your device, we don't need expensive servers or databases</li>
          <li data-i18n="about.why_free.reason2"><strong>No historical records:</strong> We focus on tree visualization, not genealogical research databases</li>
          <li data-i18n="about.why_free.reason3"><strong>Sustainable model:</strong> Our lean operation and efficient technology keep costs minimal</li>
          <li data-i18n="about.why_free.reason4"><strong>Community-driven:</strong> We're committed to serving families, not shareholders</li>
        </ul>
        <p data-i18n="about.why_free.paragraph2">We will never introduce paid features, subscriptions, or premium tiers. MapMyRoots will remain 100% free, forever.</p>
      </div>

      <div class="story-section">
        <h2 data-i18n="about.technology.title">Our Technology</h2>
        <p data-i18n="about.technology.paragraph1">MapMyRoots is built with modern web technologies to ensure a fast, secure, and reliable experience:</p>
        <ul style="font-size: 1.1rem; line-height: 1.8; color: var(--text-primary); margin-left: 2rem;">
          <li data-i18n="about.technology.canvas"><strong>HTML5 Canvas:</strong> Smooth, responsive family tree visualization</li>
          <li data-i18n="about.technology.localstorage"><strong>LocalStorage API:</strong> Secure, local data storage on your device</li>
          <li data-i18n="about.technology.responsive"><strong>Responsive Design:</strong> Works perfectly on desktop, tablet, and mobile</li>
          <li data-i18n="about.technology.export"><strong>Advanced Export:</strong> High-resolution PNG, PDF, and JSON formats</li>
          <li data-i18n="about.technology.i18n"><strong>Internationalization:</strong> Multi-language support for global accessibility</li>
        </ul>
      </div>

      <div class="cta-section">
        <h2 data-i18n="about.cta.title">Start Your Family Tree Today</h2>
        <p data-i18n="about.cta.content">Join over 15,000 families who trust MapMyRoots to preserve their family history. No registration required, completely free, and your data stays private.</p>
        <a href="/builder" class="btn-primary btn-large">
          <span data-i18n="about.cta.button">Start Building Free</span>
        </a>
      </div>
    </div>
</BaseLayout>
